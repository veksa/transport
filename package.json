{
  "name": "@veksa/transport",
  "version": "0.0.18",
  "description": "A reactive transport layer for messaging communication with pluggable adapters and RxJS observables",
  "homepage": "https://github.com/veksa/transport",
  "packageManager": "yarn@4.13.0",
  "engines": {
    "node": ">=16.0.0",
    "yarn": ">=3.0.0"
  },
  "author": {
    "name": "Aleksandr Khizhnyi",
    "email": "mendler88@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/veksa/transport.git"
  },
  "main": "./dist/cjs/index.cjs",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.mjs",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/cjs/index.cjs"
    }
  },
  "sideEffects": false,
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.ts"
    ]
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "transport",
    "messaging",
    "rxjs",
    "typescript",
    "communication",
    "socket",
    "reactive",
    "stream"
  ],
  "scripts": {
    "clean": "rimraf lib es dist",
    "build": "yarn clean && tsup",
    "compile": "tsc --noEmit",
    "test": "jest",
    "prepublish": "yarn build"
  },
  "peerDependencies": {
    "@veksa/logger": "^1.0.12"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@veksa/logger": "^1.0.12",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "rxjs": "^7.8.2",
    "uuid": "^13.0.0"
  }
}
